---
// Header.astro - Nagłówek główny i nawigacja
import Navigation from './Navigation.astro';
---

<header class="header">
  <div class="container header-container">
    <div class="logo-wrapper">
      <a href="/" class="logo-link">
        <img src="/logo.svg" alt="Herb Gminy Miedzna" class="logo-img" />
      </a>
    </div>
  </div>

  <Navigation />
</header>

<style>
  .header {
    background-color: #ffffff;
  }

  .header-container {
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    display: flex;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .header-container {
      justify-content: flex-start;
    }
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
  }

  .logo-link:hover {
    text-decoration: none;
    opacity: 0.9;
  }

  /* Herb/Logo pobrane jako zasób publiczny lub src/assets */
  .logo-img {
    height: 80px;
    width: auto;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .logo-title {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.1;
  }

  .logo-subtitle {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.1;
    text-transform: uppercase;
  }

</style>
