---
// Header.astro - Nagłówek główny i nawigacja
---

<header class="header">
  <div class="container header-container">
    <div class="logo-wrapper">
      <a href="/" class="logo-link">
        <img src="/logo.svg" alt="Herb Gminy Miedzna" class="logo-img" />
      </a>
    </div>
  </div>

  <nav class="main-nav">
    <div class="container nav-container">
      <ul class="nav-list">
        <li><a href="/" class="nav-item">Gmina</a></li>
        <li><a href="/odpady" class="nav-item">Gospodarka odpadami</a></li>
        <li><a href="/kontakt" class="nav-item">Kontakt</a></li>
        <li><a href="/bip" class="nav-item">BIP</a></li>
      </ul>
      
      <div class="nav-search">
        <button class="search-btn" aria-label="Szukaj">
          <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"></circle><line x1="21" y1="21" x2="16.65" y2="16.65"></line></svg>
        </button>
      </div>
    </div>
  </nav>
</header>

<style>
  .header {
    background-color: #ffffff;
  }

  .header-container {
    padding-top: var(--spacing-lg);
    padding-bottom: var(--spacing-lg);
    display: flex;
    justify-content: center;
  }

  @media (min-width: 768px) {
    .header-container {
      justify-content: flex-start;
    }
  }

  .logo-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    text-decoration: none;
  }

  .logo-link:hover {
    text-decoration: none;
    opacity: 0.9;
  }

  /* Herb/Logo pobrane jako zasób publiczny lub src/assets */
  .logo-img {
    height: 80px;
    width: auto;
  }

  .logo-text {
    display: flex;
    flex-direction: column;
    justify-content: center;
  }

  .logo-title {
    font-size: 1.5rem;
    font-weight: 500;
    color: var(--color-text);
    line-height: 1.1;
  }

  .logo-subtitle {
    font-size: 2rem;
    font-weight: 700;
    color: var(--color-primary);
    line-height: 1.1;
    text-transform: uppercase;
  }

  /* Nawigacja */
  .main-nav {
    background-color: var(--color-primary);
    color: white;
  }

  .nav-container {
    display: flex;
    justify-content: space-between;
    align-items: center;
  }

  .nav-list {
    display: flex;
    list-style: none;
    margin: 0;
    padding: 0;
    overflow-x: auto;
  }

  .nav-item {
    display: block;
    color: white;
    text-decoration: none;
    padding: 1rem 1.5rem;
    font-weight: 500;
    transition: background-color 0.2s;
  }

  .nav-item:hover, .nav-item:focus {
    background-color: var(--color-primary-dark);
    text-decoration: none;
  }

  .nav-search {
    padding: 0 1rem;
  }

  .search-btn {
    background: none;
    border: none;
    color: white;
    cursor: pointer;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 0.5rem;
    border-radius: 50%;
    transition: background-color 0.2s;
  }

  .search-btn:hover {
    background-color: var(--color-primary-dark);
  }
</style>
