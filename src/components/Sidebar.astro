---
// Sidebar.astro - Boczny pasek z widgetami informacyjnymi
import fs from 'fs';
import path from 'path';

let latestWarning = null;
let warningsList = [];

try {
  const uploadDir = path.join(process.cwd(), 'public', 'uploads');
  if (fs.existsSync(uploadDir)) {
    const files = fs.readdirSync(uploadDir);
    const pdfs = files.filter(f => f.startsWith('MZW_STAN_') && f.endsWith('.pdf'));

    if (pdfs.length > 0) {
      pdfs.sort((a, b) => b.localeCompare(a));
      const latestFile = pdfs[0];

      const match = latestFile.match(/MZW_STAN_(\d{4})(\d{2})(\d{2})/);
      latestWarning = {
        file: latestFile,
        date: match ? `${match[3]}.${match[2]}.${match[1]}` : "Aktualne"
      };

      // Wczytaj z czystego SSOT JSONa:
      const dataFilePath = path.join(process.cwd(), 'src', 'data', 'latest-warning.json');
      if (fs.existsSync(dataFilePath)) {
         const dataFile = fs.readFileSync(dataFilePath, 'utf8');
         const parsed = JSON.parse(dataFile);
         if (parsed && parsed.file === latestFile && parsed.warningsList) {
             warningsList = parsed.warningsList;
         }
      }
    }
  }
} catch (err) {}
---

<aside class="sidebar-wrapper">
  
  <div class="widget widget-alert">
    <div class="widget-header">
      <span class="widget-title">Ostrzeżenia meteorologiczne</span>
    </div>
    <div class="widget-body">
      {latestWarning ? (
        <div class="warning-card">
          <div class="warning-icon">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m21.73 18-8-14a2 2 0 0 0-3.48 0l-8 14A2 2 0 0 0 4 21h16a2 2 0 0 0 1.73-3Z"></path><path d="M12 9v4"></path><path d="M12 17h.01"></path></svg>
          </div>
          <div class="warning-details">
            <span class="warning-date">Data wydania: <strong>{latestWarning.date}</strong></span>
            
            {warningsList.length > 0 ? (
              warningsList.map(w => (
                <div class="warning-extracted">
                  <div class="warning-threat">{w.threat}</div>
                  {w.validity && <div class="warning-validity">{w.validity}</div>}
                </div>
              ))
            ) : (
                <div class="warning-extracted">
                  <div class="warning-threat">Wykryto dokument ostrzegawczy z dnia {latestWarning.date}</div>
                </div>
            )}
            
          </div>
        </div>
      ) : (
        <p class="no-alerts">Brak aktualnych ostrzeżeń</p>
      )}
    </div>
  </div>

  <div class="widget widget-banner bg-blue">
    <a href="#" class="banner-link">
      <img src="https://gmina-miedzna.pl/wp-content/uploads/2022/01/logo-ochrona-ludnosci.png" alt="Ochrona Ludności i Obrona Cywilna" class="banner-img" onerror="this.src='https://placehold.co/300x250/1e4b85/ffffff?text=Ochrona+Ludno%C5%9Bci'" />
      <span class="sr-only">Dowiedz się jak reagować w sytuacjach zagrożenia</span>
    </a>
  </div>

  <div class="widget widget-banner">
    <a href="#" class="banner-link">
      <img src="https://gmina-miedzna.pl/wp-content/uploads/2020/09/mazowsze-bez-smogu.png" alt="Mazowsze bez smogu" class="banner-img" onerror="this.src='https://placehold.co/300x100/f8f9fa/1e4b85?text=Mazowsze+bez+smogu'" />
    </a>
  </div>

  <div class="widget widget-banner">
    <a href="#" class="banner-link">
      <img src="https://gmina-miedzna.pl/wp-content/uploads/2021/03/flaga.jpg" alt="Unia Europejska" class="banner-img" onerror="this.src='https://placehold.co/300x120/f8f9fa/1e4b85?text=Unia+Europejska'" />
    </a>
  </div>
  
  <div class="widget widget-banner">
    <a href="#" class="banner-link text-banner">
      <div class="text-banner-content">
        <h3>Powiadomienia SMS</h3>
        <span class="btn">Zapisz się</span>
      </div>
    </a>
  </div>

</aside>

<style>
  .sidebar-wrapper {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
  }

  .widget {
    background: var(--color-bg-card);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
  }

  .widget-header {
    background: var(--color-bg);
    padding: 0.75rem 1rem;
    border-bottom: 1px solid var(--color-border);
  }

  .widget-title {
    font-weight: 600;
    color: var(--color-text);
    font-size: 0.95rem;
    text-transform: uppercase;
  }

  .widget-body {
    padding: 1.5rem 1rem;
    text-align: center;
  }

  .no-alerts {
    color: var(--color-text-light);
    font-size: 0.9rem;
    margin: 0;
  }

  /* --- Widget Ostrzeżeń --- */
  .widget-alert {
    border-color: #f59e0b;
  }
  .widget-alert .widget-header {
    background-color: #fffbeb;
    color: #b45309;
    border-bottom: 1px solid #fde68a;
  }
  
  .warning-card {
    display: flex;
    text-align: left;
    gap: 1rem;
    padding: 0.5rem 0;
  }
  
  .warning-icon {
    color: #ef4444; /* Czerwony alarmowy */
    flex-shrink: 0;
    margin-top: 0.25rem;
  }
  
  .warning-details {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .warning-date {
    font-size: 0.85rem;
    color: var(--color-slate-600);
  }
  
  .warning-extracted {
    background: #fef2f2;
    border-left: 3px solid #ef4444;
    padding: 0.75rem;
    border-radius: 0 4px 4px 0;
    margin-bottom: 0.5rem;
  }
  
  .warning-threat {
    font-weight: 700;
    color: #991b1b;
    font-size: 0.95rem;
    line-height: 1.3;
  }
  
  .warning-area {
    font-size: 0.85rem;
    color: #b91c1c;
    margin-top: 0.2rem;
    font-style: italic;
  }
  
  .warning-validity {
    margin-top: 0.25rem;
    font-size: 0.8rem;
    color: #7f1d1d;
  }

  .btn-warning {
    display: inline-block;
    background-color: #f59e0b;
    color: #fff !important;
    text-align: center;
    padding: 0.5rem 1rem;
    border-radius: 4px;
    font-size: 0.85rem;
    font-weight: 600;
    text-decoration: none;
    transition: background 0.2s;
  }
  
  .btn-warning:hover {
    background-color: #d97706;
  }

  .widget-banner {
    border: none;
    background: transparent;
    box-shadow: none;
  }

  .banner-link {
    display: block;
    width: 100%;
    border-radius: var(--radius-md);
    overflow: hidden;
    box-shadow: var(--shadow-sm);
    transition: var(--transition);
  }

  .banner-link:hover {
    transform: translateY(-2px);
    box-shadow: var(--shadow-md);
  }

  .banner-img {
    width: 100%;
    height: auto;
    display: block;
    object-fit: cover;
  }

  .bg-blue .banner-link {
    background-color: var(--color-primary-dark);
    display: flex;
    flex-direction: column;
    align-items: center;
    color: var(--color-text-on-dark);
  }

  .sr-only {
    position: absolute;
    width: 1px;
    height: 1px;
    padding: 0;
    margin: -1px;
    overflow: hidden;
    clip: rect(0, 0, 0, 0);
    white-space: nowrap;
    border-width: 0;
  }

  .text-banner {
    background-color: var(--color-slate-100);
    border: 1px solid var(--color-border);
    text-align: center;
    text-decoration: none !important;
  }

  .text-banner-content {
    padding: 2rem 1rem;
  }

  .text-banner h3 {
    color: var(--color-text);
    margin-bottom: 1rem;
    font-size: 1.25rem;
  }
</style>
