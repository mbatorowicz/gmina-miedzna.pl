---
// Layout.astro
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { siteConfig } from '../config/site';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | {siteConfig.name}</title>
    
    <!-- Meta dla SEO -->
    <meta name="description" content={siteConfig.description} />

    <!-- Skrypt WCAG - Ładuje się jako pierwszy, zapobiega zjawisku FOUC (mruganie starego stylu) -->
    <script is:inline>
      try {
        const theme = localStorage.getItem('wcag-theme');
        if (theme === 'high-contrast') document.documentElement.setAttribute('data-theme', 'high-contrast');
        
        const fontSize = localStorage.getItem('wcag-fontsize');
        if (fontSize) document.documentElement.setAttribute('data-fontsize', fontSize);
      } catch (e) {}
    </script>
  </head>
  <body>
    <TopBar />
    <Header />
    
    <main class="main-content">
      <slot />
    </main>
    
    <!-- Przeprojektowana SSOT Stopka 3-kolumnowa -->
    <Footer />
  </body>
</html>

<style>
  .main-content {
    flex: 1;
    width: 100%;
  }
</style>
