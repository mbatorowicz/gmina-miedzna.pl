---
// Layout.astro
import '../styles/global.css';
import TopBar from '../components/TopBar.astro';
import Header from '../components/Header.astro';

export interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="pl">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/logo.svg" />
    <meta name="generator" content={Astro.generator} />
    <title>{title} | Gmina Miedzna</title>
    
    <!-- Meta dla SEO -->
    <meta name="description" content="Oficjalny portal informacyjny Gminy Miedzna. Aktualności, gospodarka odpadami, kontakt." />
  </head>
  <body>
    <TopBar />
    <Header />
    
    <main class="main-content">
      <slot />
    </main>
    
    <!-- Prosta stopka na start -->
    <footer style="background: var(--color-primary-dark); color: white; padding: 2rem 0; margin-top: auto; text-align: center;">
      <div class="container">
        <p>&copy; {new Date().getFullYear()} Urząd Gminy Miedzna. Wszelkie prawa zastrzeżone.</p>
      </div>
    </footer>
  </body>
</html>

<style>
  .main-content {
    flex: 1;
    width: 100%;
  }
</style>
