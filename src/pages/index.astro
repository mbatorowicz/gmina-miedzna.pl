---
// index.astro
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import PostCard from '../components/PostCard.astro';

// Pobierz wszystkie wpisy i posortuj od najnowszego
const allNews = await getCollection('news');
const sortedNews = allNews.sort((a, b) => new Date(b.data.date).valueOf() - new Date(a.data.date).valueOf());

---

<Layout title="Strona Główna">
  <div class="container main-layout">
    
    <section class="content-area">
      <div class="news-grid">
        {sortedNews.length > 0 ? (
          sortedNews.map(post => {
            // Ścieżka do miniatury z wykorzystaniem wbudowanych funkcji Astro
            // W Astro Content Collections (relatywne obrazki w fronmatterze) musimy je obsłużyć,
            // Ale na głównym widoku najprościej pokazać je przez .src w obiekcie, gdy jest zadeklarowane jako image()
            
            const coverUrl = post.data.coverImage ? post.data.coverImage.src : undefined;
            
            // Formatowanie daty dla widoku publicznego
            const dateStr = new Date(post.data.date).toLocaleDateString('pl-PL', {
              day: 'numeric', month: 'long', year: 'numeric'
            });

            return (
              <PostCard 
                title={post.data.title}
                date={dateStr}
                author={post.data.author}
                category={post.data.categoryName}
                imageUrl={coverUrl}
                url={`/${post.data.category}/${post.id || post.slug}`}
              />
            )
          })
        ) : (
          <div style="grid-column: 1 / -1; text-align: center; padding: 3rem; background: var(--color-bg-card); border-radius: 8px;">
            <p style="color: var(--color-slate-500); font-size: 1.1rem;">Brak komunikatów do wyświetlenia.</p>
          </div>
        )}
      </div>
    </section>
    
    <Sidebar />

  </div>
</Layout>
