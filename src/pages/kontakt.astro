---
import Layout from '../layouts/Layout.astro';
import Sidebar from '../components/Sidebar.astro';
import { siteConfig } from '../config/site';
---

<Layout title="Kontakt - Gmina Miedzna">
  <div class="container main-layout">
    
    <section class="content-area">
      <article class="single-post card">
        <div class="post-header">
           <span class="category-badge">Informacje</span>
           <h1 class="post-title">Kontakt z Urzędem</h1>
        </div>
        
        <div class="post-body">
          <h2>Urząd Gminy w Miedznie</h2>
          <p>
            {siteConfig.contact.addressLine1}<br/>
            {siteConfig.contact.addressLine2}
          </p>

          <div class="contact-box">
            <h3>Dane kontaktowe</h3>
            <ul>
              {siteConfig.contact.phones.map(phone => (
                <li><strong>Telefon/fax:</strong> {phone}</li>
              ))}
              <li><strong>E-mail:</strong> {siteConfig.contact.email}</li>
              <li><strong>e-Doręczenia:</strong> {siteConfig.contact.eDoreczenia}</li>
              <li><strong>NIP:</strong> {siteConfig.contact.nip}</li>
              <li><strong>REGON:</strong> {siteConfig.contact.regon}</li>
            </ul>
          </div>

          <h3>Numery rachunków bankowych</h3>
          <ul style="list-style: none; padding: 0; margin-bottom: 2rem;">
            {siteConfig.bankAccounts.map(account => (
              <li style="margin-bottom: 0.5rem">
                <strong>{account.number}</strong> – {account.name}
              </li>
            ))}
          </ul>

          <h3>Godziny urzędowania</h3>
          <table class="hours-table">
            {siteConfig.officeHours.map(time => (
              <tr>
                <td>{time.day}</td>
                <td>{time.hours}</td>
              </tr>
            ))}
          </table>

          <h3>Elektroniczna Skrzynka Podawcza (ePUAP)</h3>
          <p>Adres skrytki ePUAP: <strong>{siteConfig.contact.epuap}</strong></p>
        </div>
      </article>
    </section>
    
    <Sidebar />

  </div>
</Layout>

<style>
  .single-post {
    padding: 0;
    overflow: hidden;
  }
  
  .post-header {
    padding: 2rem 2rem 1.5rem;
    background: var(--color-slate-50);
    border-bottom: 1px solid var(--color-border);
  }
  
  .category-badge {
    display: inline-block;
    background: var(--color-primary-light);
    color: white;
    padding: 0.25rem 0.75rem;
    border-radius: 4px;
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    margin-bottom: 1rem;
  }
  
  .post-title {
    font-size: 2rem;
    line-height: 1.2;
    color: var(--color-text);
  }

  .post-body {
    padding: 2rem;
    font-size: 1.1rem;
    line-height: 1.7;
    color: var(--color-slate-800);
  }

  .contact-box {
    background-color: var(--color-slate-100);
    border-left: 4px solid var(--color-primary);
    padding: 1.5rem;
    margin: 2rem 0;
    border-radius: 0 var(--radius-sm) var(--radius-sm) 0;
  }

  .contact-box h3 {
    margin-top: 0;
    margin-bottom: 1rem;
    color: var(--color-primary);
  }

  .contact-box ul {
    list-style: none;
    padding: 0;
    margin: 0;
  }

  .contact-box li {
    margin-bottom: 0.5rem;
  }

  .hours-table {
    width: 100%;
    max-width: 400px;
    border-collapse: collapse;
    margin: 1rem 0 2rem;
  }

  .hours-table td {
    padding: 0.75rem;
    border-bottom: 1px solid var(--color-slate-200);
  }
  
  .hours-table td:first-child {
    font-weight: 600;
    color: var(--color-text);
    width: 60%;
  }
</style>
